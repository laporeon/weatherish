#!/usr/bin/env bash
set -euo pipefail

# Weatherish launcher script (Linux/macOS)

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
JAR_PATH="$SCRIPT_DIR/target/weatherish.jar"
JAVA_CMD="${JAVA_CMD:-java}"

if [[ ! -f "$JAR_PATH" ]]; then
  echo "Error: JAR not found at: $JAR_PATH" >&2
  echo "Build it with: mvn clean package" >&2
  exit 1
fi

exec "$JAVA_CMD" -Dfile.encoding=UTF-8 -jar "$JAR_PATH"